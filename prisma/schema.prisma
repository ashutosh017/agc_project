// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String   @id
  slug             String   @unique
  name             String
  brand            String
  price            Float
  category         String
  featured         Boolean  @default(false)
  images           String[]
  shortDescription String
  description      String
  specs            Json
  features         String[]
  variants         Json?
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
